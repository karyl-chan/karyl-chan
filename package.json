{
  "name": "karyl-chan",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the karyl-chan Discord bot and its plugin SDK.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:sdk": "pnpm --filter @karyl-chan/plugin-sdk build",
    "build:bot": "pnpm --filter @karyl-chan/bot build",
    "test": "pnpm -r test",
    "lint": "pnpm -r --if-present lint",
    "clean": "pnpm -r exec rm -rf dist build dist-test node_modules && rm -rf node_modules",
    "docker:up": "docker compose -f packages/bot/docker-compose.yml up -d --build",
    "docker:down": "docker compose -f packages/bot/docker-compose.yml down"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "sqlite3",
      "esbuild"
    ]
  }
}
