{
  "name": "@karyl-chan/plugin-sdk",
  "version": "0.4.0",
  "description": "Shared SDK for karyl-chan plugins — handles HMAC, server boilerplate, register/heartbeat lifecycle.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./web": {
      "import": "./src/web/index.ts",
      "types": "./src/web/index.ts"
    },
    "./web/vue": {
      "import": "./src/web/vue/index.ts",
      "types": "./src/web/vue/index.ts"
    }
  },
  "files": [
    "dist",
    "src/web"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/karyl-chan/karyl-chan.git",
    "directory": "packages/plugin-sdk"
  },
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\"",
    "clean": "rm -rf dist dist-test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.0.0"
  },
  "peerDependencies": {
    "discord-api-types": ">=0.38.0 <0.39.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "discord-api-types": "^0.38.47",
    "typescript": "^5.6.0",
    "vue": "^3.5.0"
  }
}
