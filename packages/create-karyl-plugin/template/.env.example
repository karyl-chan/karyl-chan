# Where the bot's plugin API lives. In local dev this is the bot's
# web server; in docker it's the bot service hostname.
BOT_URL=http://localhost:3000

# Per-plugin setup secret. Generate it in the bot admin UI
# (Plugins → your plugin → Security → Generate setup secret) and paste it
# here. Without it the plugin starts its HTTP server but does NOT register
# with the bot (no commands, no events).
KARYL_PLUGIN_SETUP_SECRET=

# The URL the bot uses to reach THIS plugin (reverse RPC + dispatch).
# Defaults to http://<plugin-key>:3000 (docker hostname). Set explicitly
# when running locally or behind a different hostname.
PLUGIN_URL=http://localhost:4000

# Port / host this plugin's HTTP server listens on.
PORT=4000
HOST=0.0.0.0
