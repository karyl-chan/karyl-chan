# bind-mounted SQLite (host <-> docker share); keep the dir, ignore the
# DB. `**/` so the pattern matches packages/bot/data/, not just a
# (non-existent) repo-root data/ directory.
**/data/database.sqlite
**/data/database.sqlite-*
**/data/*.bak

