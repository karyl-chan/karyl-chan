strict-peer-dependencies=false
auto-install-peers=true

# Force sqlite3 specifically to source-build. Its prebuilt binary
# links GLIBC_2.38, which neither the WSL dev box (glibc 2.35) nor
# the Docker bullseye base (glibc 2.31) can load; building against
# the host glibc is portable. @discordjs/opus is NOT in this list —
# its arm64 source build is broken (opus NEON intrinsics bug) and
# its glibc-2.31 prebuilt covers both Docker arches, so we let
# node-pre-gyp download the prebuilt for opus.
build_from_source=sqlite3

# Disable the side-effects (post-build artifact) cache. It's keyed by
# package version, not by build_from_source, so a once-cached prebuilt
# binary would otherwise be replayed on later installs and defeat the
# sqlite3 source build above. Only two native deps exist, so the cost
# is small.
side-effects-cache=false
